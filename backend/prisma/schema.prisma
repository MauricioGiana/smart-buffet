// Smart-Buffet — base schema
// Generator and datasource only; models live in their own domain files.
// Rules:
//   - All IDs: @db.Uuid
//   - All PK constraints mapped as pk_<tablename>
//   - All DB columns snake_case via @map
//   - All TS fields camelCase
//   - No enums — use VarChar strings, validate in Domain layer
//   - ON DELETE Restrict on all FKs
//   - Every model has tenant_id (UUID, indexed)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
