// ─── Menu ─────────────────────────────────────────────────────────────────────

model Menu {
  id         String @id(map: "pk_menus") @default(uuid()) @db.Uuid @map("id")
  tenantId   String @db.Uuid                                        @map("tenant_id")
  businessId String @db.Uuid                                        @map("business_id")

  name     String  @db.VarChar(255) @map("name")
  // status validated in Domain layer (e.g. "active" | "inactive")
  isActive Boolean @default(true)   @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt       @map("updated_at")

  business   Business       @relation(fields: [businessId], references: [id], onDelete: Restrict)
  categories MenuCategory[]

  @@index([tenantId],   map: "idx_menus_tenant_id")
  @@index([businessId], map: "idx_menus_business_id")
  @@map("menus")
}

// ─── Menu Category ────────────────────────────────────────────────────────────

model MenuCategory {
  id       String @id(map: "pk_menu_categories") @default(uuid()) @db.Uuid @map("id")
  tenantId String @db.Uuid                                                  @map("tenant_id")
  menuId   String @db.Uuid                                                  @map("menu_id")

  name     String @db.VarChar(255) @map("name")
  position Int    @default(0)      @map("position")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt       @map("updated_at")

  menu  Menu       @relation(fields: [menuId], references: [id], onDelete: Restrict)
  items MenuItem[]

  @@index([tenantId], map: "idx_menu_categories_tenant_id")
  @@index([menuId],   map: "idx_menu_categories_menu_id")
  @@map("menu_categories")
}

// ─── Menu Item (Product) ──────────────────────────────────────────────────────

model MenuItem {
  id         String @id(map: "pk_menu_items") @default(uuid()) @db.Uuid @map("id")
  tenantId   String @db.Uuid                                             @map("tenant_id")
  categoryId String @db.Uuid                                             @map("category_id")

  name        String  @db.VarChar(255)  @map("name")
  description String? @db.VarChar(1000) @map("description")
  imageUrl    String? @db.VarChar(2048) @map("image_url")

  priceInCents Int     @map("price_in_cents")
  // availability validated in Domain layer (e.g. "available" | "unavailable" | "out_of_stock")
  isAvailable  Boolean @default(true) @map("is_available")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt       @map("updated_at")

  category MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([tenantId],   map: "idx_menu_items_tenant_id")
  @@index([categoryId], map: "idx_menu_items_category_id")
  @@map("menu_items")
}
