/// Independent Menu entity belonging to a Tenant.
model Menu {
  id          String    @id @default(uuid()) @db.Uuid @map("pk_menu")
  tenantId    String    @db.Uuid @map("tenant_id")
  name        String    @db.VarChar(100)
  description String?   @db.VarChar(500)
  status      String    @default("ACTIVE") @db.VarChar(30)

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categories  MenuToCategory[]

  @@index([tenantId], map: "ix_menu_tenant_id")
  @@map("menus")
}

/// Linking table to manage Category order per Menu.
model MenuToCategory {
  menuId      String @db.Uuid @map("menu_id")
  categoryId  String @db.Uuid @map("category_id")
  order       Int    @default(0)

  menu        Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([menuId, categoryId], map: "pk_menu_to_category")
  @@map("menu_to_categories")
}

/// Reusable Product groups.
model Category {
  id        String    @id @default(uuid()) @db.Uuid @map("pk_category")
  tenantId  String    @db.Uuid @map("tenant_id")
  name      String    @db.VarChar(100)
  status    String    @default("ACTIVE") @db.VarChar(30)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  menus     MenuToCategory[]
  products  CategoryToProduct[]

  @@index([tenantId], map: "ix_category_tenant_id")
  @@map("categories")
}

/// Linking table to manage Product order per Category.
model CategoryToProduct {
  categoryId String @db.Uuid @map("category_id")
  productId  String @db.Uuid @map("product_id")
  order      Int    @default(0)

  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([categoryId, productId], map: "pk_category_to_product")
  @@map("category_to_products")
}

/// Core Product entity with multi-tenant SKU uniqueness.
model Product {
  id          String    @id @default(uuid()) @db.Uuid @map("pk_product")
  tenantId    String    @db.Uuid @map("tenant_id")
  name        String    @db.VarChar(255)
  description String?   @db.VarChar(1000)
  price       Decimal   @db.Decimal(12, 2)
  sku         String?   @db.VarChar(50) 
  imageUrl    String?   @db.VarChar(500) @map("image_url")
  status      String    @default("AVAILABLE") @db.VarChar(30)

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categories  CategoryToProduct[]

  /// Ensures SKU is unique per tenant only for active products.
  @@unique([tenantId, sku, deletedAt], map: "uk_product_tenant_sku_active")
  /// Faster global lookups by SKU.
  @@index([sku], map: "ix_product_sku")
  @@map("products")
}