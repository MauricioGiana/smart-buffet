// ─── Tenant (Root) ────────────────────────────────────────────────────────────
// Represents a gastronomy business / SaaS tenant.
// Tenant IS the multi-tenancy root entity.

model Tenant {
  id   String @id(map: "pk_tenants") @default(uuid()) @db.Uuid @map("id")

  name String @db.VarChar(255) @map("name")
  slug String @unique @db.VarChar(100) @map("slug")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt       @map("updated_at")

  members TenantMember[]
  menus   Menu[]

  @@map("tenants")
}
