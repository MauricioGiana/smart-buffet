// ─── Auth ─────────────────────────────────────────────────────────────────────
// User: global identity record (email + password hash).
// TenantMember: join table linking a User to a Tenant with a role string.
//   role is validated in the Domain layer — e.g. "owner" | "manager" | "staff"

model User {
  id           String @id(map: "pk_users") @default(uuid()) @db.Uuid @map("id")

  email        String @unique @db.VarChar(255) @map("email")
  passwordHash String @db.VarChar(255)         @map("password_hash")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt       @map("updated_at")

  memberships TenantMember[]

  @@map("users")
}

model TenantMember {
  id       String @id(map: "pk_tenant_members") @default(uuid()) @db.Uuid @map("id")
  tenantId String @db.Uuid                                                 @map("tenant_id")

  userId String @db.Uuid @map("user_id")

  // Domain-validated values: "owner" | "manager" | "staff"
  role String @db.VarChar(30) @map("role")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt       @map("updated_at")

  user   User   @relation(fields: [userId],   references: [id], onDelete: Restrict)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([userId, tenantId], map: "uq_tenant_members_user_tenant")
  @@index([tenantId], map: "idx_tenant_members_tenant_id")
  @@index([userId],   map: "idx_tenant_members_user_id")
  @@map("tenant_members")
}
