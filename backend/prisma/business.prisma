// ─── Business ─────────────────────────────────────────────────────────────────
// Root tenant entity. For this model, tenant_id == id (the business IS the
// tenant). Kept explicit for schema consistency across all tables.

model Business {
  id       String @id(map: "pk_businesses") @default(uuid()) @db.Uuid @map("id")
  tenantId String @db.Uuid                                              @map("tenant_id")

  name String @db.VarChar(255) @map("name")
  slug String @unique @db.VarChar(255) @map("slug")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt       @map("updated_at")

  menus Menu[]

  @@index([tenantId], map: "idx_businesses_tenant_id")
  @@map("businesses")
}
